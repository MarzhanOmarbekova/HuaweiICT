# --- Ключи для скачивания модели из OBS ---
HUAWEI_OBS_ACCESS_KEY=твой_access_key
HUAWEI_OBS_SECRET_KEY=твой_secret_key
HUAWEI_OBS_ENDPOINT=obs.ap-southeast-1.myhuaweicloud.com
HUAWEI_OBS_BUCKET=voltai-models

# --- Путь к локальной модели (тот, что ищет views.py) ---
# Если не задать, код будет искать файл прямо в папке optimization/
MINDSPORE_CHECKPOINT=optimization/wind_cnn_best.ckpt

# --- Настройки ModelArts (если используешь облачный инференс) ---
# Если оставить пустыми, Django будет использовать локальный .ckpt
MODELARTS_ENDPOINT=
MODELARTS_TOKEN=