# VoltAI Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# Backend API URL
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api

# Huawei Petal Maps Web API Key
# Get from: https://developer.huawei.com -> Console -> Petal Maps -> Web Service
# After creating project, enable "Map JS API" and copy the key
NEXT_PUBLIC_PETAL_MAPS_KEY=YOUR_PETAL_MAPS_KEY_HERE
